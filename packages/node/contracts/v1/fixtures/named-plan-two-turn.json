{
  "name": "run-messages",
  "policy": {
    "returnPartial": true,
    "stopOnError": true
  },
  "steps": [
    {
      "command": "session.bootstrap",
      "id": "bootstrap"
    },
    {
      "command": "threads.new",
      "id": "new"
    },
    {
      "args": {
        "read": {
          "format": "markdown"
        },
        "text": "First visible turn.",
        "wait": true
      },
      "command": "messages.ask",
      "id": "first"
    },
    {
      "args": {
        "read": {
          "format": "markdown"
        },
        "text": "Second visible turn.",
        "wait": true
      },
      "command": "messages.ask",
      "id": "second"
    }
  ]
}
