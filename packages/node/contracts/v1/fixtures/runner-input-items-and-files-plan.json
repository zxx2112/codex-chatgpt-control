{
  "name": "agent-run:file-agent",
  "policy": {
    "returnPartial": true,
    "stopOnError": true
  },
  "steps": [
    {
      "command": "session.bootstrap",
      "id": "bootstrap"
    },
    {
      "command": "threads.new",
      "id": "new"
    },
    {
      "args": {
        "model": "auto"
      },
      "command": "modes.set",
      "id": "mode"
    },
    {
      "args": {
        "ifUnavailable": "skip",
        "tool": "web_search"
      },
      "command": "tools.select",
      "id": "tool1"
    },
    {
      "args": {
        "paths": [
          "/tmp/contract-fixtures/handoff.md",
          "/tmp/contract-fixtures/context.json"
        ]
      },
      "command": "files.attach",
      "id": "attach"
    },
    {
      "args": {
        "read": {
          "format": "markdown"
        },
        "text": "<chatgpt_browser_agent>\nAgent name: file-agent\nInstructions:\nUse the attached file context.\n</chatgpt_browser_agent>\n\n<user_request>\n<visible_instructions>\nUse concise bullets.\n</visible_instructions>\n\nReview the implementation handoff.\n\nAttached file context: SDK parity handoff.\n</user_request>",
        "wait": false
      },
      "command": "messages.ask",
      "id": "ask"
    }
  ]
}
