{
  "name": "agent-run:visible-prefix-agent",
  "policy": {
    "returnPartial": true,
    "stopOnError": true
  },
  "steps": [
    {
      "command": "session.bootstrap",
      "id": "bootstrap"
    },
    {
      "command": "threads.new",
      "id": "new"
    },
    {
      "args": {
        "effort": "Thinking"
      },
      "command": "modes.set",
      "id": "mode"
    },
    {
      "args": {
        "read": {
          "format": "markdown"
        },
        "text": "<chatgpt_browser_agent>\nAgent name: visible-prefix-agent\nInstructions:\nAnswer with terse implementation guidance.\n</chatgpt_browser_agent>\n\n<user_request>\nAssess the SDK architecture.\n</user_request>",
        "wait": true
      },
      "command": "messages.ask",
      "id": "ask"
    }
  ]
}
