{
  "name": "agent-run:visible-setup-agent",
  "policy": {
    "returnPartial": true,
    "stopOnError": true
  },
  "steps": [
    {
      "command": "session.bootstrap",
      "id": "bootstrap"
    },
    {
      "command": "threads.new",
      "id": "new"
    },
    {
      "args": {
        "effort": "Thinking"
      },
      "command": "modes.set",
      "id": "mode"
    },
    {
      "args": {
        "read": false,
        "text": "<chatgpt_browser_agent>\nAgent name: visible-setup-agent\nInstructions:\nMaintain a careful review checklist.\n</chatgpt_browser_agent>\n\nAcknowledge these visible setup instructions briefly, then wait for the next user request.",
        "wait": true
      },
      "command": "messages.ask",
      "id": "agent_setup"
    },
    {
      "args": {
        "read": {
          "format": "markdown"
        },
        "text": "Review parity gates.",
        "wait": true
      },
      "command": "messages.ask",
      "id": "ask"
    }
  ]
}
