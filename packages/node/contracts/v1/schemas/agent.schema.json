{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/agent.schema.json",
  "type": "object",
  "required": ["kind", "name", "instructionsMode", "defaults", "tools", "guardrails"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "chatgpt_browser_agent" },
    "name": { "type": "string", "minLength": 1 },
    "instructions": { "type": "string" },
    "instructionsMode": {
      "enum": ["visible_prefix", "visible_setup_message", "metadata_only"]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "risk": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "scope"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "scope": { "enum": ["input", "plan", "step", "output", "report"] }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
