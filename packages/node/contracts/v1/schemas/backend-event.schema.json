{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/backend-event.schema.json",
  "type": "object",
  "required": ["schemaVersion", "type"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "chatgpt.browser_control.backend_event.v1" },
    "requestId": { "type": "string", "minLength": 1 },
    "type": {
      "enum": ["run_item_stream_event", "agent_updated_stream_event", "completed", "error"]
    },
    "name": { "type": "string", "minLength": 1 },
    "item": {
      "type": "object",
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "additionalProperties": true
    },
    "result": {},
    "error": { "$ref": "#/$defs/protocolError" }
  },
  "oneOf": [
    {
      "required": ["name", "item"],
      "properties": {
        "type": { "const": "run_item_stream_event" },
        "name": { "type": "string", "minLength": 1 },
        "item": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    {
      "required": ["agent"],
      "properties": {
        "type": { "const": "agent_updated_stream_event" },
        "agent": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    {
      "required": ["result"],
      "properties": {
        "type": { "const": "completed" },
        "result": {}
      }
    },
    {
      "required": ["error"],
      "properties": {
        "type": { "const": "error" },
        "error": { "$ref": "#/$defs/protocolError" }
      }
    }
  ],
  "$defs": {
    "protocolError": {
      "type": "object",
      "required": ["code", "message", "recoverable"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "recoverable": { "type": "boolean" }
      }
    }
  }
}
