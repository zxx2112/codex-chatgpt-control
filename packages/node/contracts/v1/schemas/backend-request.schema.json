      "enum": [
        "backend.version",
        "backend.health",
        "backend.capabilities",
        "runner.run",
        "runner.plan",
        "runner.stream",
        "responses.create",
        "ask",
        "askInThread",
        "askWithFiles",
        "askAndDownload",
        "runMessages",
        "openThread",
        "readLatest",
        "copyLatest",
        "downloadLatest",
        "runPlan",
        "doctor",
        "createReport",
        "reports.create",
        "reports.redact",
        "reports.summarize",
        "commands",
        "describe",
        "help",
        "session.bootstrap",
        "experience.detect",
        "experience.open",
        "configuration.inspect",
        "configuration.apply",
        "work.start",
        "work.status",
        "work.wait",
        "work.steer",
        "work.readLatest",
        "threads.new",
        "threads.search",
        "threads.open",
        "messages.compose",
        "messages.submit",
        "messages.ask",
        "messages.wait",
        "messages.readLatest",
        "messages.status",
        "messages.waitAndRead",
        "artifacts.listLatest",
