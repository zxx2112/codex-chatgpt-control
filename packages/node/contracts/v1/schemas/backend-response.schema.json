{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/backend-response.schema.json",
  "type": "object",
  "required": ["schemaVersion", "ok"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "chatgpt.browser_control.backend_response.v1" },
    "requestId": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "result": {},
    "error": { "$ref": "#/$defs/protocolError" }
  },
  "oneOf": [
    {
      "required": ["result"],
      "properties": {
        "ok": { "const": true },
        "result": {}
      }
    },
    {
      "required": ["error"],
      "properties": {
        "ok": { "const": false },
        "error": { "$ref": "#/$defs/protocolError" }
      }
    }
  ],
  "$defs": {
    "protocolError": {
      "type": "object",
      "required": ["code", "message", "recoverable"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "recoverable": { "type": "boolean" }
      }
    }
  }
}
