{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/capabilities.schema.json",
  "type": "object",
  "required": ["protocolVersion", "commands", "transports", "streaming"],
  "additionalProperties": false,
  "properties": {
    "protocolVersion": { "const": "chatgpt.browser_control.backend_request.v1" },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "transports": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["stdio", "http"] }
    },
    "streaming": {
      "type": "object",
      "required": ["modes", "tokenDeltas"],
      "additionalProperties": false,
      "properties": {
        "modes": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["ndjson", "sse"] }
        },
        "tokenDeltas": { "const": false }
      }
    }
  }
}
