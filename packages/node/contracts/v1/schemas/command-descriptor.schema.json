{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/command-descriptor.schema.json",
  "type": "object",
  "required": ["name", "layer", "summary", "risk", "args", "defaults", "retryPolicy", "blockers", "examples"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "layer": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "risk": { "enum": ["low", "medium", "high"] },
    "defaultTimeoutMs": { "type": "integer", "minimum": 0 },
    "args": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "retryPolicy": { "type": "string", "minLength": 1 },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "examples": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
