{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/command-result.schema.json",
  "type": "object",
  "required": ["ok", "status", "warnings", "context"],
  "additionalProperties": true,
  "properties": {
    "ok": { "type": "boolean" },
    "status": { "$ref": "#/$defs/commandStatus" },
    "data": {},
    "output_text": { "type": "string" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reportPath": { "type": "string" },
    "error": {
      "type": "object",
      "required": ["name", "message", "recoverable"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "recoverable": { "type": "boolean" }
      }
    },
    "blocker": {
      "type": "object",
      "required": ["kind", "message"],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "visibleText": { "type": "string" },
        "code": { "type": "string" },
        "fieldPath": { "type": "string" },
        "remediation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "instruction", "userActionRequired"],
            "additionalProperties": true,
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "instruction": { "type": "string", "minLength": 1 },
              "userActionRequired": { "type": "boolean" }
            }
          }
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label"],
            "additionalProperties": true,
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "role": { "type": "string" }
            }
          }
        },
        "resumable": { "type": "boolean" }
      }
    },
    "context": {
      "type": "object",
      "required": ["timestamp"],
      "additionalProperties": true,
      "properties": {
        "timestamp": { "type": "string", "minLength": 1 }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "command", "status", "ok", "startedAt", "endedAt", "warnings"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "status": { "$ref": "#/$defs/commandStatus" },
          "ok": { "type": "boolean" },
          "startedAt": { "type": "string", "minLength": 1 },
          "endedAt": { "type": "string", "minLength": 1 },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "$defs": {
    "commandStatus": {
      "enum": ["ok", "partial", "timeout", "blocked", "needs_confirmation", "not_found", "unsupported", "error"]
    }
  }
}
