{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/manifest.schema.json",
  "type": "object",
  "required": ["schemaVersion", "contractVersion", "wireCase", "schemas", "fixtures"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "chatgpt.browser_control.contract_manifest.v1" },
    "contractVersion": { "type": "string", "minLength": 1 },
    "wireCase": { "const": "camelCaseWithDocumentedAliases" },
    "schemas": {
      "type": "object",
      "required": [
        "runResult",
        "response",
        "streamEvent",
        "commandDescriptor",
        "commandResult",
        "sequencePlan",
        "agent",
        "backendRequest",
        "backendResponse",
        "backendEvent",
        "capabilities",
        "surfaceProfile"
      ],
      "additionalProperties": false,
      "properties": {
        "runResult": { "type": "string", "minLength": 1 },
        "response": { "type": "string", "minLength": 1 },
        "streamEvent": { "type": "string", "minLength": 1 },
        "commandDescriptor": { "type": "string", "minLength": 1 },
        "commandResult": { "type": "string", "minLength": 1 },
        "sequencePlan": { "type": "string", "minLength": 1 },
        "agent": { "type": "string", "minLength": 1 },
        "backendRequest": { "type": "string", "minLength": 1 },
        "backendResponse": { "type": "string", "minLength": 1 },
        "backendEvent": { "type": "string", "minLength": 1 },
        "capabilities": { "type": "string", "minLength": 1 },
        "surfaceProfile": { "type": "string", "minLength": 1 }
      }
    },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "schema", "case"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "schema": {
            "enum": [
              "runResult",
              "response",
              "streamEvent",
              "commandDescriptor",
              "commandResult",
              "sequencePlan",
              "agent",
              "backendRequest",
              "backendResponse",
              "backendEvent",
              "capabilities",
              "surfaceProfile"
            ]
          },
          "case": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
