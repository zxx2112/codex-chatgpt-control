{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-chatgpt-control/contracts/v1/stream-event.schema.json",
  "type": "object",
  "required": ["type"],
  "additionalProperties": true,
  "properties": {
    "type": {
      "enum": ["run_item_stream_event", "agent_updated_stream_event", "completed", "error"]
    },
    "name": { "type": "string" },
    "item": {
      "type": "object",
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
